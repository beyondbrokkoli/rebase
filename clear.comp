#version 460
#extension GL_GOOGLE_include_directive : require
#include "shared.glsl"

layout(set = 0, binding = 0) buffer MasterBuffer { uint data[]; } vram;

layout(local_size_x = 256) in;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < CFG_GRID_CELLS) {
        vram.data[pc.cell_counters_idx + i] = 0;
        vram.data[pc.cell_offsets_idx + i] = 0;
    }
}
